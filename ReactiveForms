import { Component, EventEmitter, Input, Output, OnInit } from '@angular/core';
import { FormBuilder, FormGroup, Validators } from '@angular/forms';
import { StaticDataService } from '@api/referential';
import { Observable } from 'rxjs';
import { map } from 'rxjs/operators';
import { SelectItem } from 'primeng/api';
import { entitiesToCRUDOptions } from '@shared/utils/input-options.util';

@Component({
  selector: 'dpw-copy-template-dialog',
  templateUrl: './copy-template-dialog.component.html'
})
export class CopyTemplateDialogComponent implements OnInit {

  @Input() visible = false;

  @Output() visibleChange = new EventEmitter<boolean>();
  @Output() confirm = new EventEmitter<any>();

  form: FormGroup;
  availableFields$!: Observable<SelectItem[]>;

  constructor(
    private fb: FormBuilder,
    private staticDataService: StaticDataService
  ) {
    this.form = this.fb.group({
      copyCount: [1, [Validators.required, Validators.min(1)]],
      fields: [[], Validators.required]
    });
  }

  ngOnInit(): void {
    this.fetchFields();
  }

  fetchFields(): void {
    const branchCode = '30004';
    const countryCode = 'FR';

    this.availableFields$ = this.staticDataService
      .getInstructionSheetParamList(branchCode, countryCode)
      .pipe(
        map((res: any[]) => {
          const entities = res.map(f => ({
            id: f.param,
            name: f.param
          }));

          return entitiesToCRUDOptions(
            entities,
            'name',
            'id',
            null,
            'id',
            true
          );
        })
      );
  }

  onConfirm(): void {
    if (this.form.valid) {
      this.confirm.emit({
        copyCount: this.form.value.copyCount,
        selectedFields: [...new Set(this.form.value.fields)],
        allFields: this.form.value.fields
      });

      this.close();
    }
  }

  close(): void {
    this.visible = false;
    this.visibleChange.emit(false);
  }
}


