import {
  Component,
  Input,
  Output,
  EventEmitter,
  OnChanges,
  OnDestroy
} from '@angular/core';

import {
  FormBuilder,
  FormGroup,
  FormArray,
  FormControl
} from '@angular/forms';

import { RequestService } from '@api/controller';
import { MappedInstructionSheet } from 'app/initiate-event/model/instruction-sheet';
import { Subscription } from 'rxjs';

import {
  buildCommonRequestKeyValue,
  buildRequestKeyValue
} from '../../config/copy-request.assembler';

@Component({
  selector: 'dpw-copy-confirmation-dialog',
  templateUrl: './copy-confirmation-dialog.component.html'
})
export class CopyConfirmationDialogComponent implements OnChanges, OnDestroy {

  @Input() visible = false;
  @Input() selectedFields: string[] = [];
  @Input() allFields: string[] = [];
  @Input() copyCount = 0;
  @Input() instructionSheet!: MappedInstructionSheet;

  @Output() visibleChange = new EventEmitter<boolean>();
  @Output() back = new EventEmitter<void>();

  form: FormGroup;
  private subscription!: Subscription;

  constructor(
    private fb: FormBuilder,
    private requestService: RequestService
  ) {
    this.form = this.fb.group({
      rows: this.fb.array([])
    });
  }

  get rows(): FormArray {
    return this.form.get('rows') as FormArray;
  }

  ngOnChanges(): void {
    if (this.visible) {
      this.initTable();
    }
  }

  ngOnDestroy(): void {
    this.subscription?.unsubscribe();
  }

  initTable(): void {
    this.rows.clear();

    for (let i = 0; i < this.copyCount; i++) {
      const group: any = {
        id: new FormControl(i + 1),
        requestName: new FormControl(`Request ${i + 1}`)
      };

      this.selectedFields.forEach(field => {
        group[field] = new FormControl('');
      });

      this.rows.push(this.fb.group(group));
    }
  }

  isValid(): boolean {
    return this.rows.controls.every(group =>
      this.selectedFields.some(field => {
        const val = group.get(field)?.value;
        return val !== null && val !== undefined && val.toString().trim() !== '';
      })
    );
  }

  deleteRow(index: number): void {
    if (this.rows.length > 1) {
      this.rows.removeAt(index);

      this.rows.controls.forEach((group, i) => {
        group.get('id')?.setValue(i + 1);
        group.get('requestName')?.setValue(`Request ${i + 1}`);
      });
    }
  }

  onCopy(): void {
    const requestParameters = this.rows.controls.map((group, index) => {

      const row = group.value;

      const requestKeyValue = buildRequestKeyValue(
        this.instructionSheet,
        row,
        this.selectedFields
      );

      const commonRequestKeyValue =
        index === 0
          ? buildCommonRequestKeyValue(this.instructionSheet)
          : [];

      return {
        id: row.id.toString(),
        requestKeyValue,
        commonRequestKeyValue
      };
    });

    this.subscription = this.requestService
      .createBulkRequest(
        '30004',
        'FR',
        'tech001',
        this.instructionSheet?.requestId,
        requestParameters
      )
      .subscribe({
        next: () => this.close(),
        error: err => console.error(err)
      });
  }

  close(): void {
    this.visible = false;
    this.visibleChange.emit(false);
  }

  goBack(): void {
    this.back.emit();
  }
}


