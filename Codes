import {
  Component,
  Input,
  Output,
  EventEmitter,
  OnChanges,
  OnDestroy
} from '@angular/core';

import { RequestService } from '@api/controller';
import { MappedInstructionSheet } from 'app/initiate-event/model/instruction-sheet';
import { Subscription } from 'rxjs';

import {
  buildCommonRequestKeyValue,
  buildRequestKeyValue
} from '../../config/copy-request.assembler';

@Component({
  selector: 'dpw-copy-confirmation-dialog',
  templateUrl: './copy-confirmation-dialog.component.html'
})
export class CopyConfirmationDialogComponent implements OnChanges, OnDestroy {

  @Input() visible = false;
  @Input() selectedFields: string[] = [];
  @Input() allFields: string[] = [];
  @Input() copyCount = 0;
  @Input() request: any;
  @Input() instructionSheet!: MappedInstructionSheet;

  @Output() visibleChange = new EventEmitter<boolean>();
  @Output() back = new EventEmitter<void>();

  tableData: any[] = [];
  private subscription!: Subscription;

  constructor(private requestService: RequestService) {}

  ngOnChanges(): void {
    if (this.visible) {
      this.initTable();
    }
  }

  ngOnDestroy(): void {
    this.subscription?.unsubscribe();
  }

  initTable(): void {
    this.tableData = Array.from({ length: this.copyCount }, (_, i) => {
      const row: any = {
        id: i + 1,
        requestName: `Request ${i + 1}`
      };

      this.selectedFields.forEach(field => {
        row[field] = '';
      });

      return row;
    });
  }

  isValid(): boolean {
    return this.tableData.every(row =>
      this.selectedFields.some(field => {
        const val = row[field];
        return val !== null && val !== undefined && val.toString().trim() !== '';
      })
    );
  }

  deleteRow(index: number): void {
    if (this.tableData.length > 1) {
      this.tableData.splice(index, 1);

      this.tableData.forEach((row, i) => {
        row.id = i + 1;
        row.requestName = `Request ${i + 1}`;
      });
    }
  }

  onCopy(): void {
    const requestParameters = this.tableData.map((row, index) => {

      const requestKeyValue = buildRequestKeyValue(
        this.instructionSheet,
        row,
        this.selectedFields
      );

      const commonRequestKeyValue =
        index === 0
          ? buildCommonRequestKeyValue(this.instructionSheet)
          : [];

      return {
        id: row.id.toString(),
        requestKeyValue,
        commonRequestKeyValue
      };
    });

    this.subscription = this.requestService
      .createBulkRequest(
        '30004',
        'FR',
        'tech001',
        this.instructionSheet?.requestId,
        requestParameters
      )
      .subscribe({
        next: () => this.close(),
        error: err => console.error(err)
      });
  }

  close(): void {
    this.visible = false;
    this.visibleChange.emit(false);
  }

  goBack(): void {
    this.back.emit();
  }
}


