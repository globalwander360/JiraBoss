<p-dialog header="Confirm Copy"
  [(visible)]="visible"
  [modal]="true"
  [style]="{ width: '1000px' }">

  <button pButton icon="pi pi-arrow-left"
    class="p-button-text"
    (click)="goBack()">
  </button>

  <p-table
    [value]="tableData"
    [scrollable]="true"
    scrollHeight="400px"
    scrollDirection="both"
    styleClass="p-datatable-sm">

    <!-- HEADER -->
    <ng-template pTemplate="header">
      <tr>
        <th>Request Name</th>
        <th *ngFor="let field of selectedFields">
          {{ field }}
        </th>
        <th style="width: 80px">Action</th>
      </tr>
    </ng-template>

    <!-- BODY -->
    <ng-template pTemplate="body" let-row let-rowIndex="rowIndex">
      <tr>
        <td>{{ row.requestName }}</td>

        <td *ngFor="let field of selectedFields">
          <input pInputText [(ngModel)]="row[field]" />
        </td>

        <td style="text-align:center">
          <button pButton icon="pi pi-trash"
            class="p-button-danger p-button-text"
            (click)="deleteRequest(rowIndex)"
            [disabled]="tableData.length === 1">
          </button>
        </td>
      </tr>
    </ng-template>

  </p-table>

  <ng-template pTemplate="footer">
    <button pButton label="Cancel"
      class="p-button-text"
      (click)="close()">
    </button>

    <button pButton label="Copy"
      class="p-button-success"
      (click)="onCopy()"
      [disabled]="!isFormValid()">
    </button>
  </ng-template>

</p-dialog>


