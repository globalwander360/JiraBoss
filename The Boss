🚀 1. COPY TEMPLATE DIALOG (CONFIG SCREEN)

✅ copy-template-dialog.component.ts

import { Component, EventEmitter, Input, Output, OnInit } from '@angular/core';
import { FormBuilder, FormGroup, Validators } from '@angular/forms';
import { StaticDataService } from '@api/referential';

@Component({
  selector: 'app-copy-template-dialog',
  templateUrl: './copy-template-dialog.component.html',
  styleUrls: ['./copy-template-dialog.component.scss']
})
export class CopyTemplateDialogComponent implements OnInit {

  @Input() visible = false;
  @Output() visibleChange = new EventEmitter<boolean>();
  @Output() confirm = new EventEmitter<any>();

  form: FormGroup;

  availableFields: Array<{ label: string; value: string }> = [];

  constructor(
    private fb: FormBuilder,
    private staticDataService: StaticDataService
  ) {
    this.form = this.fb.group({
      copyCount: [1, [Validators.required, Validators.min(1)]],
      fields: [[], Validators.required]
    });
  }

  ngOnInit(): void {
    this.fetchAvailableFields();
  }

  fetchAvailableFields(): void {
    const branchCode = '30004';
    const countryCode = 'FR';

    this.staticDataService.getInstructionSheetParamList(branchCode, countryCode)
      .subscribe({
        next: (response: any[]) => {
          this.availableFields = response.map(field => ({
            label: field.param,
            value: field.columnName
          }));
        },
        error: () => {
          this.availableFields = [{ label: 'None', value: 'none' }];
        }
      });
  }

  onConfirm(): void {
    if (this.form.valid) {
      const selectedFields = [...new Set(this.form.value.fields)]; // prevent duplicate

      this.confirm.emit({
        copyCount: this.form.value.copyCount,
        selectedFields
      });

      this.close();
    }
  }

  close(): void {
    this.visible = false;
    this.visibleChange.emit(false);
  }
}


