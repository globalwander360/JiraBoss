🚀 2. COPY CONFIRMATION DIALOG (TABLE SCREEN)

✅ copy-confirmation-dialog.component.ts

import { Component, Input, Output, EventEmitter, OnChanges } from '@angular/core';
import { RequestService } from '@api/controller';

@Component({
  selector: 'app-copy-confirmation-dialog',
  templateUrl: './copy-confirmation-dialog.component.html',
  styleUrls: ['./copy-confirmation-dialog.component.scss']
})
export class CopyConfirmationDialogComponent implements OnChanges {

  @Input() visible = false;
  @Input() selectedFields: string[] = [];
  @Input() copyCount = 0;

  @Output() visibleChange = new EventEmitter<boolean>();
  @Output() back = new EventEmitter<void>();

  tableData: any[] = [];

  branchCode = '30004';
  countryCode = 'FR';
  bnppuid = 'tech001';

  constructor(private requestService: RequestService) {}

  ngOnChanges(): void {
    if (this.visible) {
      this.initializeTable();
    }
  }

  initializeTable(): void {
    this.tableData = Array.from({ length: this.copyCount }, (_, index) => {
      const row: any = {
        id: index + 1,
        requestName: `Request ${index + 1}`
      };

      this.selectedFields.forEach(field => row[field] = '');
      return row;
    });
  }

  isFormValid(): boolean {
    return this.tableData.every(row =>
      this.selectedFields.every(field => row[field])
    );
  }

  deleteRequest(index: number): void {
    if (this.tableData.length > 1) {
      this.tableData.splice(index, 1);
    }
  }

  goBack(): void {
    this.back.emit();
  }

  close(): void {
    this.visible = false;
    this.visibleChange.emit(false);
  }

  onCopy(): void {
    const requestParameters = this.tableData.map(row => ({
      requestKeyValue: this.selectedFields.map(field => ({
        id: row.id,
        key: field,
        value: row[field]
      }))
    }));

    this.requestService.createBulkRequest(
      this.branchCode,
      this.countryCode,
      this.bnppuid,
      undefined,
      requestParameters
    ).subscribe({
      next: () => {
        console.log('Bulk request created');
        this.close();
      },
      error: (err) => {
        console.error('Error:', err);
      }
    });
  }
}


