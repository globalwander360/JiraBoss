import {
  buildRequestKeyValue,
  buildCommonRequestKeyValue
} from '../../assembler/copy-request.assembler';

onCopy(): void {
  const requestParameters = this.tableData.map((row, index) => {

    const requestKeyValue = buildRequestKeyValue(
      this.instructionSheet,
      row,
      this.selectedFields
    );

    const commonRequestKeyValue =
      index === 0
        ? buildCommonRequestKeyValue(this.instructionSheet)
        : [];

    return {
      id: row.id.toString(),
      requestKeyValue,
      commonRequestKeyValue
    };
  });

  console.log('FINAL REQUEST PARAMETERS:', JSON.stringify(requestParameters, null, 2));

  this.requestService.createBulkRequest(
    '30004',
    'FR',
    'tech001',
    undefined,
    requestParameters
  ).subscribe({
    next: () => this.close(),
    error: (err) => console.error(err)
  });
}


