import { MappedInstructionSheet } from 'app/initiate-event/model/instruction-sheet';

/**
 * 🔹 Helper: row value override > fallback (instructionSheet)
 */
function getValue(row: any, key: string, fallback: any) {
  return row[key] !== undefined && row[key] !== null && row[key] !== ''
    ? row[key]
    : fallback ?? null;
}

/**
 * 🔹 Build Request Key Value (DYNAMIC)
 */
export function buildRequestKeyValue(
  instructionSheet: MappedInstructionSheet,
  row: any,
  selectedFields: string[]
) {
  const { event, customer, information } = instructionSheet;

  const fieldList = [
    {
      key: 'Customer Id',
      value: getValue(row, 'Customer Id', customer?.customerId)
    },
    {
      key: 'Customer Name',
      value: getValue(row, 'Customer Name', customer?.customerName)
    },
    {
      key: 'Amount',
      value: getValue(row, 'Amount', event?.amount)
    },
    {
      key: 'Currency',
      value: getValue(row, 'Currency', event?.currency?.initialCurrency)
    },
    {
      key: 'Customer Account',
      value: getValue(row, 'Customer Account', customer?.accountNumber)
    },
    {
      key: 'Business Center',
      value: getValue(row, 'Business Center', customer?.businessCenter)
    },
    {
      key: 'Main Folder Ref',
      value: getValue(row, 'Main Folder Ref', information?.mainFolderRef)
    },
    {
      key: 'Util. Main Folder Ref',
      value: getValue(row, 'Util. Main Folder Ref', information?.utilMainFolderRef)
    },
    {
      key: 'Linked Division Ref',
      value: getValue(row, 'Linked Division Ref', information?.linkedDivisionRef)
    },
    {
      key: 'Connexis tnx ID',
      value: getValue(row, 'Connexis tnx ID', information?.connexisRequestTnxId)
    },
    {
      key: 'Customer ref',
      value: getValue(row, 'Customer ref', information?.customerRef)
    },
    {
      key: 'Counterparty Country',
      value: getValue(row, 'Counterparty Country', event?.country?.countryCode)
    }
  ];

  // 🔹 Only selected fields return
  return fieldList.filter(f => selectedFields.includes(f.key));
}

/**
 * 🔹 Build Common Key Value (ONLY ONCE)
 */
export function buildCommonRequestKeyValue(
  instructionSheet: MappedInstructionSheet
) {
  const { initiation, jurisdiction } = instructionSheet;

  return [
    {
      key: 'Processing Entity',
      value: jurisdiction?.processingEntity?.name || null
    },
    {
      key: 'Branch Code',
      value: jurisdiction?.branch?.code || null
    },
    {
      key: 'Branch Name',
      value: jurisdiction?.branch?.name || null
    },
    {
      key: 'Sector',
      value: jurisdiction?.sector?.name || null
    },
    {
      key: 'Division',
      value: jurisdiction?.division?.name || null
    },
    {
      key: 'SubDivision',
      value: jurisdiction?.subdivision?.name || null
    },
    {
      key: 'Country Code',
      value: jurisdiction?.branch?.location?.countryCode || null
    },
    {
      key: 'Request Reception Date and Time',
      value: initiation?.requestReceptionDate || null
    },
    {
      key: 'Revised Request Date and Time',
      value: initiation?.revisedRequestDateTime || null
    },
    {
      key: 'Status in UV',
      value: 'Qualification'
    }
  ];
}


