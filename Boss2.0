🚀 5. PARENT CONNECTION

✅ initiate-event.component.ts

copyCount = 0;
selectedFields: string[] = [];
allFields: string[] = [];

isCopyTemplateDialogVisible = false;
isCopyConfirmationDialogVisible = false;

onCopyTemplateConfigured(config: any): void {
  this.copyCount = config.copyCount;
  this.selectedFields = config.selectedFields;
  this.allFields = config.allFields;

  this.isCopyTemplateDialogVisible = false;
  this.isCopyConfirmationDialogVisible = true;
}

onBackFromConfirmation(): void {
  this.isCopyConfirmationDialogVisible = false;
  this.isCopyTemplateDialogVisible = true;
}


