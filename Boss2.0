🚀 3. COPY TEMPLATE DIALOG

✅ copy-template-dialog.component.ts

import { Component, EventEmitter, Input, Output, OnInit } from '@angular/core';
import { FormBuilder, FormGroup, Validators } from '@angular/forms';
import { StaticDataService } from '@api/referential';

@Component({
  selector: 'app-copy-template-dialog',
  templateUrl: './copy-template-dialog.component.html'
})
export class CopyTemplateDialogComponent implements OnInit {

  @Input() visible = false;
  @Output() visibleChange = new EventEmitter<boolean>();
  @Output() confirm = new EventEmitter<any>();

  form: FormGroup;
  availableFields: any[] = [];
  allFields: string[] = [];

  constructor(private fb: FormBuilder, private staticDataService: StaticDataService) {
    this.form = this.fb.group({
      copyCount: [1, [Validators.required, Validators.min(1)]],
      fields: [[], Validators.required]
    });
  }

  ngOnInit(): void {
    this.fetchFields();
  }

  fetchFields(): void {
    this.staticDataService.getInstructionSheetParamList('30004', 'FR')
      .subscribe((res: any[]) => {
        this.availableFields = res.map(f => ({
          label: f.param,
          value: f.columnName
        }));

        this.allFields = this.availableFields.map(f => f.value);
      });
  }

  onConfirm(): void {
    if (this.form.valid) {
      this.confirm.emit({
        copyCount: this.form.value.copyCount,
        selectedFields: [...new Set(this.form.value.fields)],
        allFields: this.allFields
      });
      this.close();
    }
  }

  close(): void {
    this.visible = false;
    this.visibleChange.emit(false);
  }
}


---

✅ copy-template-dialog.component.html

<p-dialog header="Copy" [(visible)]="visible" [modal]="true" [style]="{width:'600px'}">

  <form [formGroup]="form" class="p-fluid">

    <div class="field">
      <label>Number of Copies</label>
      <input type="number" pInputText formControlName="copyCount" />
    </div>

    <div class="field">
      <label>Select Fields</label>
      <p-multiSelect
        [options]="availableFields"
        formControlName="fields"
        optionLabel="label"
        optionValue="value"
        [filter]="true"
        appendTo="body">
      </p-multiSelect>
    </div>

  </form>

  <ng-template pTemplate="footer">
    <button pButton label="Cancel" (click)="close()"></button>
    <button pButton label="Confirm"
      class="p-button-success"
      (click)="onConfirm()"
      [disabled]="!form.valid">
    </button>
  </ng-template>

</p-dialog>


