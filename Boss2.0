🚀 1. CONFIG FILE (DYNAMIC MAPPING)

✅ field-mapping.config.ts

export interface FieldMappingConfig {
  field: string;
  source?: string;
  defaultValue?: any;
}

export const FIELD_MAPPING_CONFIG: FieldMappingConfig[] = [

  { field: 'MFR', source: 'instructionSheet.mfr' },
  { field: 'UMFR', source: 'instructionSheet.umfr' },
  { field: 'CORRESPONDENT_REF', source: 'instructionSheet.correspondentRef' },

  { field: 'CURRENCY', source: 'instructionSheet.currency' },
  { field: 'AMOUNT', source: 'instructionSheet.amount' },

  { field: 'STATUS', defaultValue: 'NEW' }

];


---

🚀 2. RESOLVER (CORE LOGIC)

✅ field-value.resolver.ts

import { FIELD_MAPPING_CONFIG } from '../config/field-mapping.config';

export class FieldValueResolver {

  static resolve(field: string, row: any, context: any, selectedFields: string[]): any {

    // 1. User input priority
    if (selectedFields.includes(field) && row[field]) {
      return row[field];
    }

    // 2. Config mapping
    const config = FIELD_MAPPING_CONFIG.find(f => f.field === field);

    if (config?.source) {
      return this.getValueFromPath(context, config.source);
    }

    // 3. Default value
    if (config?.defaultValue !== undefined) {
      return config.defaultValue;
    }

    return null;
  }

  private static getValueFromPath(obj: any, path: string): any {
    return path.split('.').reduce((acc, key) => acc?.[key], obj);
  }
}


