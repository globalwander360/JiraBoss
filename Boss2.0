🚀 4. COPY CONFIRMATION DIALOG

✅ copy-confirmation-dialog.component.ts

import { Component, Input, Output, EventEmitter, OnChanges } from '@angular/core';
import { RequestService } from '@api/controller';
import { FieldValueResolver } from '../../utils/field-value.resolver';

@Component({
  selector: 'app-copy-confirmation-dialog',
  templateUrl: './copy-confirmation-dialog.component.html'
})
export class CopyConfirmationDialogComponent implements OnChanges {

  @Input() visible = false;
  @Input() selectedFields: string[] = [];
  @Input() allFields: string[] = [];
  @Input() copyCount = 0;
  @Input() instructionSheet: any;

  @Output() visibleChange = new EventEmitter<boolean>();
  @Output() back = new EventEmitter<void>();

  tableData: any[] = [];

  constructor(private requestService: RequestService) {}

  ngOnChanges(): void {
    if (this.visible) {
      this.initTable();
    }
  }

  initTable(): void {
    this.tableData = Array.from({ length: this.copyCount }, (_, i) => {
      const row: any = { id: i + 1, requestName: `Request ${i + 1}` };
      this.selectedFields.forEach(f => row[f] = '');
      return row;
    });
  }

  isValid(): boolean {
    return this.tableData.every(row =>
      this.selectedFields.every(f => row[f])
    );
  }

  deleteRow(i: number): void {
    if (this.tableData.length > 1) {
      this.tableData.splice(i, 1);
    }
  }

  onCopy(): void {

    const context = { instructionSheet: this.instructionSheet };

    const payload = this.tableData.map(row => ({
      requestKeyValue: this.allFields.map(field => ({
        id: row.id,
        key: field,
        value: FieldValueResolver.resolve(field, row, context, this.selectedFields)
      }))
    }));

    this.requestService.createBulkRequest('30004','FR','tech001',undefined,payload)
      .subscribe(() => this.close());
  }

  close(): void {
    this.visible = false;
    this.visibleChange.emit(false);
  }

  goBack(): void {
    this.back.emit();
  }
}


---

✅ copy-confirmation-dialog.component.html

<p-dialog header="Confirm Copy" [(visible)]="visible" [modal]="true" [style]="{width:'1000px'}">

  <button pButton icon="pi pi-arrow-left" (click)="goBack()"></button>

  <p-table [value]="tableData" [scrollable]="true" scrollHeight="400px">

    <ng-template pTemplate="header">
      <tr>
        <th>Request</th>
        <th *ngFor="let f of selectedFields">{{f}}</th>
        <th>Action</th>
      </tr>
    </ng-template>

    <ng-template pTemplate="body" let-row let-i="rowIndex">
      <tr>
        <td>{{row.requestName}}</td>

        <td *ngFor="let f of selectedFields">
          <input pInputText [(ngModel)]="row[f]" />
        </td>

        <td>
          <button pButton icon="pi pi-trash"
            (click)="deleteRow(i)"
            [disabled]="tableData.length===1">
          </button>
        </td>
      </tr>
    </ng-template>

  </p-table>

  <ng-template pTemplate="footer">
    <button pButton label="Cancel" (click)="close()"></button>
    <button pButton label="Copy"
      class="p-button-success"
      (click)="onCopy()"
      [disabled]="!isValid()">
    </button>
  </ng-template>

</p-dialog>


