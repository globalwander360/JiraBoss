import { FIELD_MAPPING_CONFIG } from '../config/field-mapping.config';

export class FieldValueResolver {

  static resolve(field: string, row: any, context: any, selectedFields: string[]): any {

    // ✅ Correct user value check
    const hasUserValue =
      selectedFields.includes(field) &&
      Object.prototype.hasOwnProperty.call(row, field) &&
      row[field] !== null &&
      row[field] !== undefined &&
      row[field] !== '';

    if (hasUserValue) {
      return row[field];
    }

    // ✅ Config lookup
    const config = FIELD_MAPPING_CONFIG.find(f => f.field === field);

    // ✅ Source fallback
    if (config?.source) {
      return this.getValueFromPath(context, config.source);
    }

    // ✅ Default fallback
    if (config?.defaultValue !== undefined) {
      return config.defaultValue;
    }

    return null;
  }

  private static getValueFromPath(obj: any, path: string): any {
    return path.split('.').reduce((acc, key) => acc?.[key], obj);
  }
}


