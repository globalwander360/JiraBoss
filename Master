initTable(): void {
  this.tableData = Array.from({ length: this.copyCount }, (_, i) => {

    const row: any = {
      id: i + 1,
      requestName: `Request ${i + 1}`
    };

    this.selectedFields.forEach(field => {
      const configValue = REQUEST_PAYLOAD_TEMPLATE.requestKeyValue.find(f => f.key === field);
      row[field] = configValue ? configValue.value : '';
    });

    return row;
  });
}


